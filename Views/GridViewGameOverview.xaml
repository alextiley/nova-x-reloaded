                    <!--  Achievement bar  -->
                    <Expander
                      Grid.Row="{DynamicResource GridViewSectionOrderPlayniteAchievementSummary}"
                      Margin="0,0,5,0"
                      IsExpanded="True"
                      Visibility="{PluginSettings Plugin=PlayniteAchievements,
                                                  Path=HasData,
                                                  FallbackValue=Collapsed,
                                                  Converter={StaticResource BooleanToVisibilityConverter}}">
                      <Expander.Header>
                        <TextBlock
                          Cursor="Hand"
                          FontSize="{DynamicResource FontSizeLarge}"
                          FontWeight="SemiBold"
                          Style="{DynamicResource BaseTextBlockStyle}"
                          Text="{DynamicResource LOCPlayniteAchievementsAchievements}" />
                      </Expander.Header>
                      <StackPanel Margin="0,0,0,15">
                        <Separator Margin="0,5,0,5" Background="{DynamicResource GridViewSeparatorBrush}" />
                        <DockPanel Margin="-5,2,0,0">
                          <ContentControl
                            x:Name="PlayniteAchievements_PluginButton"
                            Height="28"
                            Margin="0,0,10,0"
                            VerticalAlignment="Center"
                            DockPanel.Dock="Right" />
                          <Grid
                            x:Name="PlayniteAchievements_PluginProgressBar"
                            Height="28"
                            Margin="10,5,10,5"
                            VerticalAlignment="Center"
                            DataContext="{PluginSettings Plugin=PlayniteAchievements}">

                            <Grid.Resources>
                              <LinearGradientBrush x:Key="PlatinumBrush" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#A020F0" />
                                <GradientStop Offset="0.5" Color="#8A60D4" />
                                <GradientStop Offset="1" Color="#4B0082" />
                              </LinearGradientBrush>
                              <LinearGradientBrush x:Key="GoldBrush" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0.0" Color="#FFD700" />
                                <GradientStop Offset="0.3" Color="#C5A000" />
                                <GradientStop Offset="0.7" Color="#8B6508" />
                                <GradientStop Offset="1.0" Color="#664A00" />
                              </LinearGradientBrush>
                              <LinearGradientBrush x:Key="SilverBrush" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0.0" Color="#A8A9AD" />
                                <GradientStop Offset="0.5" Color="#71797E" />
                                <GradientStop Offset="1.0" Color="#4A4E52" />
                              </LinearGradientBrush>
                              <LinearGradientBrush x:Key="BronzeBrush" StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#CD7F32" />
                                <GradientStop Offset="1" Color="#8B4513" />
                              </LinearGradientBrush>
                            </Grid.Resources>

                            <ProgressBar
                              Height="28"
                              Margin="0"
                              HorizontalAlignment="Stretch"
                              VerticalAlignment="Center"
                              Background="#77555555"
                              Foreground="{StaticResource BronzeBrush}"
                              Maximum="{Binding Path=Total, FallbackValue=0}"
                              Value="{Binding Path=Unlocked, FallbackValue=0}">
                              <ProgressBar.Template>
                                <ControlTemplate TargetType="ProgressBar">
                                  <Border BorderThickness="0" CornerRadius="3">
                                    <Grid>
                                      <TextBlock
                                        x:Name="PercentStringHelper"
                                        Text="{Binding Percent, FallbackValue=0, StringFormat={}{0:0}}"
                                        Visibility="Collapsed" />

                                      <Rectangle
                                        Fill="{TemplateBinding Background}"
                                        RadiusX="3"
                                        RadiusY="3" />
                                      <Rectangle
                                        x:Name="PART_Track"
                                        Fill="Transparent"
                                        RadiusX="3"
                                        RadiusY="3" />

                                      <Decorator
                                        x:Name="PART_Indicator"
                                        HorizontalAlignment="Left"
                                        VerticalAlignment="Stretch">
                                        <Rectangle
                                          x:Name="IndicatorRect"
                                          Fill="{TemplateBinding Foreground}"
                                          RadiusX="3"
                                          RadiusY="3" />
                                      </Decorator>

                                      <Border
                                        x:Name="FlareBorder"
                                        BorderThickness="2"
                                        CornerRadius="3"
                                        Opacity="0.85"
                                        Visibility="Collapsed">
                                        <Border.Effect>
                                          <DropShadowEffect
                                            BlurRadius="4"
                                            Opacity="0.4"
                                            ShadowDepth="0"
                                            Color="#E59D2E" />
                                        </Border.Effect>
                                        <Border.BorderBrush>
                                          <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                            <LinearGradientBrush.RelativeTransform>
                                              <RotateTransform x:Name="FlareTransform" Angle="0" CenterX="0.5" CenterY="0.5" />
                                            </LinearGradientBrush.RelativeTransform>
                                            <GradientStop Offset="0.0" Color="#00C5A000" />
                                            <GradientStop Offset="0.3" Color="#80FFD700" />
                                            <GradientStop Offset="0.5" Color="#CCFFFFFF" />
                                            <GradientStop Offset="0.7" Color="#80FFD700" />
                                            <GradientStop Offset="1.0" Color="#00C5A000" />
                                          </LinearGradientBrush>
                                        </Border.BorderBrush>
                                      </Border>
                                    </Grid>
                                  </Border>

                                  <ControlTemplate.Triggers>
                                    <DataTrigger Binding="{Binding Text, ElementName=PercentStringHelper}" Value="100">
                                      <Setter TargetName="IndicatorRect" Property="Fill" Value="{StaticResource GoldBrush}" />
                                      <Setter TargetName="FlareBorder" Property="Visibility" Value="Visible" />

                                      <DataTrigger.EnterActions>
                                        <BeginStoryboard Name="SpinFlare">
                                          <Storyboard>
                                            <DoubleAnimation
                                              RepeatBehavior="Forever"
                                              Storyboard.TargetName="FlareTransform"
                                              Storyboard.TargetProperty="Angle"
                                              From="0"
                                              To="360"
                                              Duration="0:0:3.5" />
                                          </Storyboard>
                                        </BeginStoryboard>
                                      </DataTrigger.EnterActions>

                                      <DataTrigger.ExitActions>
                                        <StopStoryboard BeginStoryboardName="SpinFlare" />
                                      </DataTrigger.ExitActions>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=PercentStringHelper}" Value="99">
                                      <Setter TargetName="IndicatorRect" Property="Fill" Value="{StaticResource GoldBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=PercentStringHelper}" Value="98">
                                      <Setter TargetName="IndicatorRect" Property="Fill" Value="{StaticResource GoldBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=PercentStringHelper}" Value="97">
                                      <Setter TargetName="IndicatorRect" Property="Fill" Value="{StaticResource GoldBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=PercentStringHelper}" Value="96">
                                      <Setter TargetName="IndicatorRect" Property="Fill" Value="{StaticResource GoldBrush}" />
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding Text, ElementName=PercentStringHelper}" Value="95">
                                      <Setter TargetName="IndicatorRect" Property="Fill" Value="{StaticResource GoldBrush}" />
