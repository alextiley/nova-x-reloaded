<ResourceDictionary
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:sys="clr-namespace:System;assembly=mscorlib"
  mc:Ignorable="d">

  <Style TargetType="{x:Type GridViewGameOverview}">
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type GridViewGameOverview}">
          <Border
            Padding="10,0,5,10"
            d:DataContext="{x:Static DesignMainViewModel.DesignSelectedGameDetailsIntance}"
            BorderBrush="{DynamicResource PanelSeparatorBrush}">
            <DockPanel Margin="{DynamicResource PanelTopPanelSeparator}">
              <Button
                Margin="0,0,15,5"
                HorizontalAlignment="Right"
                VerticalAlignment="Top"
                Command="{MainViewModel CloseGameSideBarCommand}"
                Content="&#xE8BB;"
                DockPanel.Dock="Top"
                FontFamily="Segoe MDL2 Assets"
                Style="{DynamicResource SimpleButton}" />
              <TextBlock
                Margin="0,20,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                DockPanel.Dock="Top"
                Text="{DynamicResource LOCErrorNoGameSelected}">
                <TextBlock.Style>
                  <Style BasedOn="{StaticResource BaseTextBlockStyle}" TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Style.Triggers>
                      <Trigger Property="DataContext" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Visible" />
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </TextBlock.Style>
              </TextBlock>

              <DockPanel DockPanel.Dock="Top">
                <DockPanel.Style>
                  <Style TargetType="DockPanel">
                    <Style.Triggers>
                      <Trigger Property="DataContext" Value="{x:Null}">
                        <Setter Property="Visibility" Value="Collapsed" />
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </DockPanel.Style>


                <Grid
                  x:Name="ExtraMetadataLoader_LogoLoaderControlGrid"
                  DockPanel.Dock="Top"
                  Tag="{DynamicResource GridViewAllowUseOfLogos}">
                  <Grid.Style>
                    <Style TargetType="Grid">
                      <Setter Property="Visibility" Value="Visible" />
                      <Style.Triggers>
                        <DataTrigger Binding="{PluginSettings Plugin=ExtraMetadataLoader, Path=EnableLogos, FallbackValue=False}" Value="false">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                        <DataTrigger Binding="{Binding Tag, RelativeSource={RelativeSource Self}, FallbackValue=False}" Value="false">
                          <Setter Property="Visibility" Value="Collapsed" />
                        </DataTrigger>
                      </Style.Triggers>
                    </Style>
                  </Grid.Style>
                  <Border
                    Height="{PluginSettings Plugin=ExtraMetadataLoader,
                                            Path=LogoMaxHeight,
                                            FallbackValue=0}"
                    MaxWidth="{PluginSettings Plugin=ExtraMetadataLoader,
                                              Path=LogoMaxWidth,
                                              FallbackValue=0}"
                    Padding="10,5,10,10">
                    <ContentControl x:Name="ExtraMetadataLoader_LogoLoaderControl" VerticalAlignment="Center" />
                  </Border>
                </Grid>
                <DockPanel DockPanel.Dock="Top">
                  <Image
                    Name="PART_ImageIcon"
                    MaxWidth="32"
                    MaxHeight="32"
                    Margin="0,0,10,0"
                    DockPanel.Dock="Left"
                    RenderOptions.BitmapScalingMode="Fant">
                    <Image.Clip>
                      <RectangleGeometry
                        RadiusX="4"
                        RadiusY="4"
                        Rect="0,0,32,32" />
                    </Image.Clip>
                  </Image>
                  <ContentControl
                    x:Name="NewsViewer_PlayersInGameViewerControl"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    Visibility="{PluginSettings Plugin=NewsViewer,
                                                Path=PlayersCountAvailable,
                                                FallbackValue=Collapsed,
                                                Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ContentControl.Resources>
                      <Style BasedOn="{StaticResource PlayersCountButtonStyle}" TargetType="Button" />
                    </ContentControl.Resources>
                  </ContentControl>

                  <Border
                    Margin="0,0,10,0"
                    DockPanel.Dock="Left"
                    Tag="{DynamicResource GridViewDisplayGameNameIfLogoVisible}">
                    <Border.Style>
                      <Style TargetType="Border">
                        <Setter Property="Visibility" Value="Visible" />
                        <Style.Triggers>
                          <MultiDataTrigger>
                            <MultiDataTrigger.Conditions>
                              <Condition Binding="{Binding Tag, RelativeSource={RelativeSource Self}, FallbackValue=False}" Value="False" />
                              <Condition Binding="{Binding ElementName=ExtraMetadataLoader_LogoLoaderControlGrid, Path=Visibility}" Value="Visible" />
                              <Condition Binding="{Binding ElementName=ExtraMetadataLoader_LogoLoaderControl, Path=Visibility, FallbackValue=Collapsed}" Value="Visible" />
                              <Condition Binding="{PluginSettings Plugin=ExtraMetadataLoader, Path=IsLogoAvailable, FallbackValue=False}" Value="True" />
                            </MultiDataTrigger.Conditions>
                            <Setter Property="Visibility" Value="Collapsed" />
                          </MultiDataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Border.Style>
                    <TextBlock
                      Name="PART_TextDisplayName"
                      Margin="0,20,0,20"
                      VerticalAlignment="Center"
                      FontFamily="{DynamicResource FontFamily}"
                      FontSize="{DynamicResource FontSizeLarger}"
                      FontWeight="SemiBold"
                      Foreground="White"
                      TextWrapping="Wrap" />
                  </Border>

                </DockPanel>

                <DockPanel
                  Margin="0,5,0,0"
                  DockPanel.Dock="Top"
                  LastChildFill="False">
                  <ContentControl
                    x:Name="GogSecondClassWatcher_SecondClassWatcherControl"
                    Margin="0,0,10,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    DockPanel.Dock="Right"
                    Visibility="{PluginSettings Plugin=GogSecondClassWatcher,
                                                Path=IsControlVisible,
                                                FallbackValue=Collapsed,
                                                Converter={StaticResource BooleanToVisibilityConverter}}" />
                </DockPanel>



                <Grid
                  Margin="0,0,0,10"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Top"
                  DockPanel.Dock="Top">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <Button
                    Name="PART_ButtonPlayAction"
                    Grid.Column="0"
                    Margin="0,0,3,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{DynamicResource PlayButtonViews}" />
                  <Button
                    Name="PART_ButtonContextAction"
                    Grid.Column="1"
                    Margin="0,0,3,0"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Stretch"
                    Style="{DynamicResource ContextButtonViews}" />
                  <Button
                    Name="PART_ButtonMoreActions"
                    Grid.Column="2"
                    Width="25"
                    MinWidth="0"
                    Margin="0,0,10,0"
                    Padding="0">

                    <Button.Style>
                      <Style BasedOn="{StaticResource MoreActionButtonViews}" TargetType="Button">
                        <Setter Property="Tag" Value="GreenGradient" />
                        <Style.Triggers>
                          <DataTrigger Binding="{Binding Visibility, ElementName=PART_ButtonContextAction}" Value="Visible">
                            <Setter Property="Tag" Value="BlueGradient" />
                          </DataTrigger>
                        </Style.Triggers>
                      </Style>
                    </Button.Style>

                    <Button.Content>
                      <Viewbox
                        Width="15"
                        Height="15"
                        Margin="0,5,0,0">
                        <Polygon
                          Fill="White"
                          Points="13.913,141 128,59 242.087,141"
                          RenderTransformOrigin="0.5,0.5">
                          <Polygon.RenderTransform>
                            <RotateTransform Angle="180" />
                          </Polygon.RenderTransform>
                        </Polygon>
                      </Viewbox>
                    </Button.Content>
                  </Button>
                  <Button
                    x:Name="PART_ButtonEditGame"
                    Grid.Column="3"
                    Width="32"
                    Height="32"
                    MinWidth="32"
                    MinHeight="32"
                    Margin="10,0,0,0"
                    Padding="0"
                    Focusable="False"
                    Style="{DynamicResource MoreActionButtonViews}">

                    <Button.Content>
                      <Viewbox Width="16" Height="16">
                        <Path
                          Data="M-232.755,589.942l3.103,2.408c5.78,4.492,11.973,8.18,18.409,10.959l3.581,1.547l2.276,33.783 c0.089,1.33,1.385,2.54,2.715,2.54h48.62c1.355,0,2.745-1.273,2.852-2.621l2.74-33.284l3.602-1.496 c6.406-2.656,12.646-6.262,18.554-10.707l3.137-2.366l30.578,15.009c1.155,0.571,2.924,0.017,3.563-1.087l24.303-42.1 c0.674-1.173,0.265-3.014-0.852-3.785l-27.872-19.309l0.469-3.832c0.495-4.032,0.725-7.395,0.725-10.57 c0-3.129-0.227-6.5-0.687-10.307l-0.469-3.896l28.699-19.253c1.112-0.741,1.509-2.473,0.84-3.627l-24.3-42.104 c-0.657-1.139-2.502-1.727-3.7-1.155l-31.208,14.748l-3.091-2.341c-5.571-4.224-11.466-7.688-17.522-10.306l-3.58-1.548 l-2.34-34.887c-0.089-1.33-1.381-2.536-2.715-2.536h-48.617c-1.355,0-2.74,1.274-2.851,2.626l-2.834,34.371l-3.593,1.501 c-6.082,2.535-12.028,5.924-17.667,10.071l-3.124,2.302l-31.392-15.413c-1.168-0.575-2.924-0.025-3.559,1.074l-24.309,42.107 c-0.678,1.172-0.264,3.014,0.848,3.781l28.068,19.444l-0.524,3.883c-0.592,4.378-0.865,8.018-0.865,11.462 c0,2.988,0.179,6.065,0.55,9.403l0.431,3.853l-28.528,19.125c-1.108,0.742-1.509,2.468-0.84,3.632l24.308,42.1 c0.656,1.142,2.489,1.726,3.7,1.154L-232.755,589.942z M-177.498,560.051c-19.311,0-35.02-15.709-35.02-35.02 s15.709-35.02,35.02-35.02s35.02,15.709,35.02,35.02S-158.188,560.051-177.498,560.051z"
                          Fill="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                          Stretch="Uniform" />
                      </Viewbox>
                    </Button.Content>
                  </Button>
                  <ToggleButton
                    Name="GameFavoriteToggleButton"
                    Grid.Column="4"
                    Width="32"
                    Height="32"
                    MinWidth="32"
                    MinHeight="32"
                    Margin="10,0,0,0"
                    Padding="0"
                    VerticalAlignment="Stretch"
                    Focusable="False"
                    IsChecked="{PluginSettings Plugin=ThemeExtras,
                                               Path=Game.Favorite,
                                               Mode=TwoWay,
                                               FallbackValue={StaticResource False}}"
                    Style="{DynamicResource PanelFavoriteToggleButton}"
                    Visibility="{PluginStatus Plugin=felixkmh_Extras_Plugin}" />

                  <ContentControl
                    x:Name="PlayState_GameStateSwitchControl"
                    Grid.Column="5"
                    Width="32"
                    Height="32"
                    MinWidth="32"
                    MinHeight="32"
                    Margin="10,0,0,0"
                    Padding="0"
                    VerticalAlignment="Center"
                    Visibility="{PluginSettings Plugin=PlayState,
                                                Path=IsControlVisible,
                                                FallbackValue=Collapsed,
                                                Converter={StaticResource BooleanToVisibilityConverter}}" />

                  <ContentControl
                    x:Name="DuplicateHider_SourceSelector"
                    Grid.Column="7"
                    Height="24"
                    Margin="0,0,25,0"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    RenderOptions.BitmapScalingMode="Fant"
                    Visibility="{PluginSettings Plugin=DuplicateHider,
                                                Path=EnableUiIntegration,
                                                FallbackValue=Collapsed,
                                                Converter={StaticResource BooleanToVisibilityConverter}}" />

                </Grid>

                <ScrollViewer
                  x:Name="PART_ScrollViewHost"
                  Margin="0,10,0,0"
                  HorizontalAlignment="Stretch"
                  DockPanel.Dock="Top"
                  HorizontalScrollBarVisibility="Disabled"
                  VerticalScrollBarVisibility="Auto">
                  <Grid>
                    <Grid.RowDefinitions>
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                      <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Expander
                      Grid.Row="{DynamicResource GridViewSectionOrderDetails}"
                      Margin="0,0,5,0"
                      IsExpanded="True">
                      <Expander.Header>
                        <TextBlock
                          Cursor="Hand"
                          FontSize="{DynamicResource FontSizeLarge}"
                          FontWeight="SemiBold"
                          Style="{DynamicResource BaseTextBlockStyle}"
                          Text="{DynamicResource LOCGameDetails}" />
                      </Expander.Header>
                      <StackPanel Margin="0,0,0,10">
                        <StackPanel.Resources>
                          <Style TargetType="ItemsControl">
                            <Setter Property="VerticalAlignment" Value="Center" />
                          </Style>
                          <Style BasedOn="{StaticResource {x:Type Label}}" TargetType="Label">
                            <Setter Property="Margin" Value="0,4,8,4" />
                            <Setter Property="VerticalAlignment" Value="Top" />
                            <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                          </Style>
                          <Style BasedOn="{StaticResource PropertyItemButton}" TargetType="Button" />
                        </StackPanel.Resources>
                        <Separator Margin="0,5,0,5" Background="{DynamicResource GridViewSeparatorBrush}" />
                        <GridEx
                          Margin="0,0,0,0"
                          AutoLayoutColumns="2"
                          ColumnCount="2"
                          RowCount="25"
                          StarColumns="1">
                          <Grid.Resources>
                            <Style BasedOn="{StaticResource BaseTextBlockStyle}" TargetType="TextBlock" />
                            <Style TargetType="FrameworkElement">
                              <Style.Triggers>
                                <Trigger Property="Grid.Column" Value="1">
                                  <Setter Property="Margin" Value="10,0,0,0" />
                                </Trigger>
                              </Style.Triggers>
                            </Style>
                            <Style
                              x:Key="Icon"
                              BasedOn="{StaticResource BaseTextBlockStyle}"
                              TargetType="TextBlock">
                              <Setter Property="Width" Value="24" />
                              <Setter Property="Foreground" Value="{DynamicResource GlyphBrush}" />
                              <Setter Property="FontWeight" Value="Normal" />
                              <Setter Property="Visibility" Value="{DynamicResource GridViewDetailsIconsVisibility}" />
                              <Setter Property="FontFamily" Value="Segoe MDL2 Assets" />
                              <Setter Property="VerticalAlignment" Value="Center" />
                            </Style>
                            <Style TargetType="Label">
                              <Setter Property="FontWeight" Value="Normal" />
                              <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
                            </Style>
                          </Grid.Resources>

                          <Label Name="PART_ElemPlayTime">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE121;" />
                              <TextBlock Text="{DynamicResource LOCTimePlayed}" />
                            </StackPanel>
                          </Label>
                          <TextBlock
                            Name="PART_TextPlayTime"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />

                          <Label Name="PART_ElemLastPlayed">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE163;" />
                              <TextBlock Text="{DynamicResource LOCLastPlayed}" />
                            </StackPanel>
                          </Label>
                          <TextBlock
                            Name="PART_TextLastActivity"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />

                          <Label Name="PART_ElemRecentActivity">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE163;" />
                              <TextBlock Text="{DynamicResource LOCRecentActivityLabel}" />
                            </StackPanel>
                          </Label>
                          <TextBlock
                            Name="PART_TextRecentActivity"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />

                          <Label Name="PART_ElemAdded">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE163;" />
                              <TextBlock Text="{DynamicResource LOCDateAddedLabel}" />
                            </StackPanel>
                          </Label>
                          <TextBlock
                            Name="PART_TextAdded"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />

                          <Label VerticalAlignment="Center" Visibility="{Binding ElementName=CompStatusElemsGrid, Path=Visibility}">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xF16A;" />
                              <TextBlock Text="{DynamicResource LOCCompletionStatus}" />
                            </StackPanel>
                          </Label>

                          <Grid
                            x:Name="CompStatusElemsGrid"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                            <Grid.Style>
                              <Style TargetType="Grid">
                                <Setter Property="Visibility" Value="Collapsed" />
                                <Style.Triggers>
                                  <DataTrigger Binding="{Binding ElementName=PART_ButtonCompletionStatus, Path=Visibility}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible" />
                                  </DataTrigger>
                                  <DataTrigger Binding="{Binding ElementName=ThemeExtras_SettableCompletionStatus, Path=Visibility}" Value="Visible">
                                    <Setter Property="Visibility" Value="Visible" />
                                  </DataTrigger>
                                  <DataTrigger Binding="{Settings DetailsVisibility.CompletionStatus}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                  </DataTrigger>
                                </Style.Triggers>
                              </Style>
                            </Grid.Style>

                            <ContentControl
                              x:Name="ThemeExtras_SettableCompletionStatus"
                              HorizontalAlignment="Left"
                              Visibility="{PluginStatus Plugin=felixkmh_Extras_Plugin,
                                                        Status=Installed}">
                              <ContentControl.Resources>
                                <Style BasedOn="{StaticResource ThemeExtrasUserControlCompStatusStyle}" TargetType="UserControl" />
                              </ContentControl.Resources>
                            </ContentControl>

                            <Border Tag="{PluginStatus Plugin=felixkmh_Extras_Plugin, Status=Installed}" Visibility="{Binding RelativeSource={RelativeSource Self}, Path=Tag, Converter={StaticResource InvertedBooleanToVisibilityConverter}}">
                              <Button Name="PART_ButtonCompletionStatus" VerticalAlignment="Center" />
                            </Border>
                          </Grid>


                          <Label Name="PART_ElemInstallDirectory">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE8B7;" />
                              <TextBlock Text="{DynamicResource LOCGameInstallDirTitle}" />
                            </StackPanel>
                          </Label>
                          <Button
                            Name="PART_ButtonInstallDirectory"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />

                          <Label Name="PART_ElemInstallSize">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xEDA2;" />
                              <TextBlock Text="{DynamicResource LOCInstallSizeLabel}" />
                            </StackPanel>
                          </Label>
                          <TextBlock
                            Name="PART_TextInstallSize"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />

                          <Label Name="PART_ElemReleaseDate">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE163;" />
                              <TextBlock Text="{DynamicResource LOCGameReleaseDateTitle}" />
                            </StackPanel>
                          </Label>
                          <Button
                            Name="PART_ButtonReleaseDate"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />

                          <Label Name="PART_ElemLibrary">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE1D3;" />
                              <TextBlock Text="{DynamicResource LOCGameProviderTitle}" />
                            </StackPanel>
                          </Label>
                          <Button
                            Name="PART_ButtonLibrary"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />
                          <Label Name="PART_ElemSource">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE10F;" />
                              <TextBlock Text="{DynamicResource LOCSourceLabel}" />
                            </StackPanel>
                          </Label>
                          <Button
                            Name="PART_ButtonSource"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />
                          <Label Name="PART_ElemPlatform">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE990;" />
                              <TextBlock Text="{DynamicResource LOCGamePlatformTitle}" />
                            </StackPanel>
                          </Label>
                          <ItemsControl
                            Name="PART_ItemsPlatforms"
                            Grid.Column="1"
                            Margin="10,0,0,0" />

                          <Label Name="PART_ElemCategories">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE9D5;" />
                              <TextBlock Text="{DynamicResource LOCGameCategoriesTitle}" />
                            </StackPanel>
                          </Label>
                          <ItemsControl
                            Name="PART_ItemsCategories"
                            Grid.Column="1"
                            Margin="10,0,0,0" />

                          <Label Name="PART_ElemGenres">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE9D5;" />
                              <TextBlock Text="{DynamicResource LOCGenreLabel}" />
                            </StackPanel>
                          </Label>
                          <ItemsControl
                            Name="PART_ItemsGenres"
                            Grid.Column="1"
                            Margin="10,0,0,0" />

                          <Label Name="PART_ElemDevelopers">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE125;" />
                              <TextBlock Text="{DynamicResource LOCDeveloperLabel}" />
                            </StackPanel>
                          </Label>
                          <ItemsControl
                            Name="PART_ItemsDevelopers"
                            Grid.Column="1"
                            Margin="10,0,0,0" />

                          <Label Name="PART_ElemPublishers">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE125;" />
                              <TextBlock Text="{DynamicResource LOCPublisherLabel}" />
                            </StackPanel>
                          </Label>
                          <ItemsControl
                            Name="PART_ItemsPublishers"
                            Grid.Column="1"
                            Margin="10,0,0,0" />

                          <Label Name="PART_ElemAgeRating">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE814;" />
                              <TextBlock Text="{DynamicResource LOCAgeRatingLabel}" />
                            </StackPanel>
                          </Label>
                          <ItemsControl
                            Name="PART_ItemsAgeRatings"
                            Grid.Column="1"
                            Margin="10,0,0,0" />

                          <Label Name="PART_ElemSeries">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xF003;" />
                              <TextBlock Text="{DynamicResource LOCSeriesLabel}" />
                            </StackPanel>
                          </Label>
                          <ItemsControl
                            Name="PART_ItemsSeries"
                            Grid.Column="1"
                            Margin="10,0,0,0" />

                          <Label Name="PART_ElemRegion">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE128;" />
                              <TextBlock Text="{DynamicResource LOCRegionLabel}" />
                            </StackPanel>
                          </Label>
                          <ItemsControl
                            Name="PART_ItemsRegions"
                            Grid.Column="1"
                            Margin="10,0,0,0" />

                          <Label Name="PART_ElemVersion">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xEA6A;" />
                              <TextBlock Text="{DynamicResource LOCVersionLabel}" />
                            </StackPanel>
                          </Label>
                          <Button
                            Name="PART_ButtonVersion"
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center" />

                          <Label Name="PART_ElemCommunityScore">
                            <StackPanel Orientation="Horizontal">
                              <TextBlock Style="{StaticResource Icon}" Text="&#xE734;" />
                              <TextBlock Text="{DynamicResource LOCCommunityScore}" />
                            </StackPanel>
                          </Label>
                          <StackPanel
                            Grid.Column="1"
                            Margin="10,0,0,0"
                            Orientation="Horizontal"
                            Visibility="{Binding ElementName=PART_TextCommunityScore, Path=Visibility}">
                            <TextBlock
                              Name="PART_TextCommunityScore"
                              VerticalAlignment="Center"
                              Style="{DynamicResource TextBlockGameScore}" />
                            <ContentControl
                              Height="{Binding ElementName=PART_TextCommunityScore, Path=ActualHeight}"
                              Padding="6,0,0,4"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center"
                              Background="Transparent"
                              Content="{Binding Game.CommunityScore}"
                              ContentTemplate="{StaticResource FiveStarScoreTemplate}"
                              Foreground="{Binding ElementName=PART_TextCommunityScore, Path=Foreground}" />
