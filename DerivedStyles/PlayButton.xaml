<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation" xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <Style
    x:Key="PlayButton"
    BasedOn="{StaticResource BaseStyle}"
    TargetType="{x:Type Button}">
    <Setter Property="Background" Value="{DynamicResource GlyphBrush}" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
    <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,5,10,5" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid x:Name="Grid">
            <Border
              x:Name="DefaultBorder"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="{DynamicResource ControlCornerRadius}"
              Opacity="1" />
            <ContentPresenter
              Margin="{TemplateBinding Padding}"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
              RecognizesAccessKey="True" />
          </Grid>
          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="True" />
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="DefaultBorder" Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
              <Setter TargetName="Grid" Property="Opacity" Value="0.5" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
    <Style.Triggers>
      <Trigger Property="IsMouseOver" Value="true">
        <Setter Property="Background" Value="{DynamicResource PurpleButtonBrushHighlight}" />
        <Setter Property="Foreground" Value="{DynamicResource TextBrush}" />
        <Setter Property="BorderBrush" Value="{DynamicResource TextBrush}" />
      </Trigger>
    </Style.Triggers>
  </Style>

  <Style x:Key="PlayButtonViews" TargetType="{x:Type Button}">
    <Style.Resources>
      <LinearGradientBrush x:Key="SteamPlayDefault" StartPoint="0,0.5" EndPoint="1,0.5">
        <LinearGradientBrush.RelativeTransform>
          <TransformGroup>
            <ScaleTransform CenterX="0.25" CenterY="0" ScaleX="3.3" ScaleY="1" />
          </TransformGroup>
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Offset="0.0" Color="#70d61d" />
        <GradientStop Offset="0.6" Color="#01a75b" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="SteamPlayHover" StartPoint="0,0.5" EndPoint="1,0.5">
        <LinearGradientBrush.RelativeTransform>
          <TransformGroup>
            <ScaleTransform CenterX="0" CenterY="0" ScaleX="3.3" ScaleY="1" />
          </TransformGroup>
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Offset="0.0" Color="#70d61d" />
        <GradientStop Offset="0.6" Color="#01a75b" />
      </LinearGradientBrush>
    </Style.Resources>

    <Setter Property="Background" Value="{StaticResource SteamPlayDefault}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="0,5,0,5" />
    <Setter Property="FontWeight" Value="Light" />
    <Setter Property="FontSize" Value="20" />
    <Setter Property="FontFamily" Value="Motiva Sans, Inter, Arial, sans-serif" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="MinHeight" Value="54" />
    <Setter Property="MinWidth" Value="178" />

    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid x:Name="Grid">
            <Border
              x:Name="DefaultBorder"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="2,0,0,2" />

            <Border
              x:Name="HoverBorder"
              Background="{StaticResource SteamPlayHover}"
              CornerRadius="2,0,0,2"
              Opacity="0" />

            <StackPanel
              Margin="{TemplateBinding Padding}"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
              Orientation="Horizontal">
              <Path
                Width="13"
                Height="15"
                Margin="0,0,10,0"
                Data="M65.321,33.521c-11.274-6.615-20.342-1.471-20.342,11.52V210.96c0,12.989,9.068,18.135,20.342,11.521l137.244-82.348 c11.274-6.618,11.274-17.646,0-24.509L65.321,33.521z"
                Fill="#c1ffcb"
                Stretch="Uniform" />
              <TextBlock
                VerticalAlignment="Center"
                FontFamily="{TemplateBinding FontFamily}"
                FontSize="{TemplateBinding FontSize}"
                FontWeight="{TemplateBinding FontWeight}"
                Foreground="{TemplateBinding Foreground}"
                Style="{StaticResource BaseTextBlockStyle}"
                Tag="{DynamicResource LOCPlayGame}"
                Text="{Binding RelativeSource={RelativeSource Self}, Path=Tag, Mode=OneWay, Converter={StaticResource StringToUpperCaseConverter}}" />
            </StackPanel>
          </Grid>

          <ControlTemplate.Triggers>
            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Grid" Property="Opacity" Value="0.5" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="1"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="0"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="ContextButtonViews" TargetType="{x:Type Button}">
    <Style.Resources>
      <LinearGradientBrush x:Key="SteamInstallDefault" StartPoint="0,0.5" EndPoint="1,0.5">
        <LinearGradientBrush.RelativeTransform>
          <TransformGroup>
            <ScaleTransform CenterX="0.25" CenterY="0" ScaleX="3.3" ScaleY="1" />
          </TransformGroup>
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Offset="0.0" Color="#47bfff" />
        <GradientStop Offset="0.6" Color="#1a44c2" />
      </LinearGradientBrush>
      <LinearGradientBrush x:Key="SteamInstallHover" StartPoint="0,0.5" EndPoint="1,0.5">
        <LinearGradientBrush.RelativeTransform>
          <TransformGroup>
            <ScaleTransform CenterX="0" CenterY="0" ScaleX="3.3" ScaleY="1" />
          </TransformGroup>
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Offset="0.0" Color="#47bfff" />
        <GradientStop Offset="0.6" Color="#1a44c2" />
      </LinearGradientBrush>
    </Style.Resources>

    <Setter Property="Background" Value="{StaticResource SteamInstallDefault}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,5,10,5" />
    <Setter Property="FontWeight" Value="Light" />
    <Setter Property="FontSize" Value="18" />
    <Setter Property="FontFamily" Value="Motiva Sans, Inter, Arial, sans-serif" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="MinHeight" Value="54" />
    <Setter Property="MinWidth" Value="178" />

    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid x:Name="Grid">
            <Border
              x:Name="DefaultBorder"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="2,0,0,2" />
            <Border
              x:Name="HoverBorder"
              Background="{StaticResource SteamInstallHover}"
              CornerRadius="2,0,0,2"
              Opacity="0" />

            <StackPanel
              Margin="{TemplateBinding Padding}"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
              Orientation="Horizontal">

              <Grid
                Width="20"
                Height="20"
                Margin="0,0,10,0">
                <Path
                  x:Name="Icon_INSTALL"
                  Data="M 29,23 H 29 V 27 H 7 V 23 H 2 V 32 H 34 V 23 H 29 Z M 20,14.1716 L 24.5858,9.58578 L 27.4142,12.4142 L 18,21.8284 L 8.58582,12.4142 L 11.4142,9.58578 L 16,14.1715 V 2 H 20 V 14.1716 Z"
                  Fill="#cbeeff"
                  Stretch="Uniform"
                  Visibility="Collapsed" />
                <Canvas
                  x:Name="Icon_CANCEL"
                  Width="16"
                  Height="16"
                  Visibility="Collapsed">
                  <Line
                    Stroke="#ffffff"
                    StrokeEndLineCap="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="3.5"
                    X1="2"
                    X2="14"
                    Y1="2"
                    Y2="14" />
                  <Line
                    Stroke="#ffffff"
                    StrokeEndLineCap="Round"
                    StrokeStartLineCap="Round"
                    StrokeThickness="3.5"
                    X1="14"
                    X2="2"
                    Y1="2"
                    Y2="14" />
                </Canvas>
              </Grid>

              <TextBlock
                x:Name="OriginalText"
                Text="{Binding RelativeSource={RelativeSource AncestorType={x:Type Button}}, Path=Content, Mode=OneWay, Converter={StaticResource StringToUpperCaseConverter}}"
                Visibility="Collapsed" />

              <TextBlock
                x:Name="DisplayText"
                VerticalAlignment="Center"
                FontFamily="{TemplateBinding FontFamily}"
                FontSize="{TemplateBinding FontSize}"
                FontWeight="{TemplateBinding FontWeight}"
                Foreground="{TemplateBinding Foreground}"
                Text="{Binding ElementName=OriginalText, Path=Text}" />

            </StackPanel>
          </Grid>

          <ControlTemplate.Triggers>
            <DataTrigger Binding="{Binding ElementName=OriginalText, Path=Text}" Value="INSTALL">
              <Setter TargetName="Icon_INSTALL" Property="Visibility" Value="Visible" />
              <Setter TargetName="DisplayText" Property="Text" Value="INSTALL" />
            </DataTrigger>

            <DataTrigger Binding="{Binding ElementName=OriginalText, Path=Text}" Value="INSTALLING">
              <Setter TargetName="Icon_CANCEL" Property="Visibility" Value="Visible" />
              <Setter TargetName="DisplayText" Property="Text" Value="INSTALLING" />
            </DataTrigger>

            <DataTrigger Binding="{Binding ElementName=OriginalText, Path=Text}" Value="UNINSTALLING">
              <Setter TargetName="Icon_CANCEL" Property="Visibility" Value="Visible" />
              <Setter TargetName="DisplayText" Property="Text" Value="REMOVING" />
            </DataTrigger>

            <DataTrigger Binding="{Binding ElementName=OriginalText, Path=Text}" Value="LAUNCHING">
              <Setter TargetName="Icon_CANCEL" Property="Visibility" Value="Visible" />
              <Setter TargetName="DisplayText" Property="Text" Value="LAUNCHING" />
            </DataTrigger>

            <DataTrigger Binding="{Binding ElementName=OriginalText, Path=Text}" Value="RUNNING">
              <Setter TargetName="Icon_CANCEL" Property="Visibility" Value="Visible" />
              <Setter TargetName="DisplayText" Property="Text" Value="RUNNING" />
            </DataTrigger>

            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="Grid" Property="Opacity" Value="0.5" />
            </Trigger>
            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="1"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="0"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style x:Key="MoreActionButtonViews" TargetType="{x:Type Button}">
    <Style.Resources>
      <LinearGradientBrush x:Key="SteamGreenGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <LinearGradientBrush.RelativeTransform>
          <ScaleTransform CenterX="0.25" CenterY="0" ScaleX="3.3" ScaleY="1" />
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Offset="0.0" Color="#19b14e" />
        <GradientStop Offset="0.6" Color="#19b14e" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="SteamGreenHoverGradient" StartPoint="0,0.5" EndPoint="1,0.5">
        <LinearGradientBrush.RelativeTransform>
          <ScaleTransform CenterX="0" CenterY="0" ScaleX="3.3" ScaleY="1" />
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Offset="0.0" Color="#70d61d" />
        <GradientStop Offset="0.6" Color="#01a75b" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="SteamInstallDefault" StartPoint="0,0.5" EndPoint="1,0.5">
        <LinearGradientBrush.RelativeTransform>
          <ScaleTransform CenterX="0.25" CenterY="0" ScaleX="3.3" ScaleY="1" />
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Offset="0.0" Color="#47bfff" />
        <GradientStop Offset="0.6" Color="#1a44c2" />
      </LinearGradientBrush>

      <LinearGradientBrush x:Key="SteamInstallHover" StartPoint="0,0.5" EndPoint="1,0.5">
        <LinearGradientBrush.RelativeTransform>
          <ScaleTransform CenterX="0" CenterY="0" ScaleX="3.3" ScaleY="1" />
        </LinearGradientBrush.RelativeTransform>
        <GradientStop Offset="0.0" Color="#47bfff" />
        <GradientStop Offset="0.6" Color="#1a44c2" />
      </LinearGradientBrush>
    </Style.Resources>

    <Setter Property="Background" Value="#303030" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="BorderBrush" Value="{DynamicResource NormalBorderBrush}" />
    <Setter Property="BorderThickness" Value="0" />
    <Setter Property="Padding" Value="10,5,10,5" />
    <Setter Property="FontWeight" Value="Bold" />
    <Setter Property="FontSize" Value="{DynamicResource FontSizeLarge}" />
    <Setter Property="Cursor" Value="Hand" />
    <Setter Property="MinHeight" Value="54" />
    <Setter Property="MinWidth" Value="54" />

    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <Grid x:Name="Grid">

            <Border
              x:Name="DefaultBorder"
              Background="{TemplateBinding Background}"
              BorderBrush="{TemplateBinding BorderBrush}"
              BorderThickness="{TemplateBinding BorderThickness}"
              CornerRadius="0,2,2,0" />

            <Border
              x:Name="HoverBorder"
              Background="#ffffff"
              CornerRadius="0,2,2,0"
              IsHitTestVisible="False"
              Opacity="0"
              Visibility="Visible" />

            <Border
              x:Name="GreenHoverBorder"
              Background="{StaticResource SteamGreenHoverGradient}"
              CornerRadius="0,2,2,0"
              IsHitTestVisible="False"
              Opacity="0"
              Visibility="Collapsed" />

            <Border
              x:Name="BlueHoverBorder"
              Background="{StaticResource SteamInstallHover}"
              CornerRadius="0,2,2,0"
              IsHitTestVisible="False"
              Opacity="0"
              Visibility="Collapsed" />

            <ContentPresenter
              Margin="{TemplateBinding Padding}"
              HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
              VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
              RecognizesAccessKey="True" />
          </Grid>

          <ControlTemplate.Triggers>

            <Trigger Property="Tag" Value="GreenGradient">
              <Setter TargetName="DefaultBorder" Property="Background" Value="{StaticResource SteamGreenGradient}" />
              <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed" />
              <Setter TargetName="GreenHoverBorder" Property="Visibility" Value="Visible" />
            </Trigger>

            <Trigger Property="Tag" Value="BlueGradient">
              <Setter TargetName="DefaultBorder" Property="Background" Value="{StaticResource SteamInstallDefault}" />
              <Setter TargetName="HoverBorder" Property="Visibility" Value="Collapsed" />
              <Setter TargetName="BlueHoverBorder" Property="Visibility" Value="Visible" />
            </Trigger>

            <Trigger Property="IsMouseOver" Value="True">
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="0.1"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                      Storyboard.TargetName="GreenHoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="1"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                      Storyboard.TargetName="BlueHoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="1"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetName="HoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="0"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                      Storyboard.TargetName="GreenHoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="0"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                    <DoubleAnimation
                      Storyboard.TargetName="BlueHoverBorder"
                      Storyboard.TargetProperty="Opacity"
                      To="0"
                      Duration="0:0:0.2">
                      <DoubleAnimation.EasingFunction>
                        <QuadraticEase EasingMode="EaseOut" />
                      </DoubleAnimation.EasingFunction>
                    </DoubleAnimation>
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>

            <Trigger Property="IsEnabled" Value="False">
              <Setter TargetName="DefaultBorder" Property="Background" Value="{DynamicResource DisabledBackgroundBrush}" />
              <Setter TargetName="Grid" Property="Opacity" Value="0.5" />
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>

  <Style
    x:Key="QuickEditButton"
    BasedOn="{StaticResource {x:Type Button}}"
    TargetType="{x:Type Button}">
    <Setter Property="MinHeight" Value="54" />
    <Setter Property="MinWidth" Value="54" />
    <Setter Property="Background" Value="#303030" />
    <Setter Property="Foreground" Value="{DynamicResource TextBrushDark}" />
    <Setter Property="Template">
      <Setter.Value>
        <ControlTemplate TargetType="{x:Type Button}">
          <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="true">
              <Setter Property="Cursor" Value="Hand" />
              <Trigger.EnterActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetProperty="(Button.Opacity)"
                      To="1"
                      Duration="0:0:2" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.EnterActions>
              <Trigger.ExitActions>
                <BeginStoryboard>
                  <Storyboard>
                    <DoubleAnimation
                      Storyboard.TargetProperty="(Button.Opacity)"
                      To="0.3"
                      Duration="0:0:2" />
                  </Storyboard>
                </BeginStoryboard>
              </Trigger.ExitActions>
            </Trigger>
          </ControlTemplate.Triggers>
        </ControlTemplate>
      </Setter.Value>
    </Setter>
  </Style>
</ResourceDictionary>
